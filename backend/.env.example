# Copy to .env and fill in.

# Default stack uses Z.AI (OpenAI-compatible). See https://docs.z.ai/guides/develop/openai/python
LLM_PROVIDER=zai
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-5

# OpenAI instead:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic instead:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

DATABASE_URL=sqlite:///./socratic.db

# Optional tuning
# HTTP_TIMEOUT_SECONDS=120
# LLM_MAX_RETRIES=2
# LOG_LEVEL=INFO
